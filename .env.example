# AgoraLens environment
# Copy to .env.local and fill in values. Do not commit .env.local.

# Arc testnet
NEXT_PUBLIC_ARC_CHAIN_ID=
NEXT_PUBLIC_ARC_RPC_URL=
ARC_PRIVATE_KEY_TESTNET=
NEXT_PUBLIC_MARKET_REGISTRY_ADDRESS=
NEXT_PUBLIC_RECEIPT_REGISTRY_ADDRESS=
NEXT_PUBLIC_SUBGRAPH_URL=

# Live external market source
# Defaults to https://gamma-api.polymarket.com/markets if omitted.
POLYMARKET_GAMMA_API_URL=

# Public signal source
NEWS_API_KEY=

# Circle Wallets onboarding
CIRCLE_API_KEY=
CIRCLE_ENTITY_SECRET=
CIRCLE_WALLET_SET_ID=
NEXT_PUBLIC_CIRCLE_ENV=
